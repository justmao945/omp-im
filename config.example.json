{
  "agents": ["omp", "claude", "codex"],
  "projects": [
    {
      "name": "default",
      "work_dir": "/path/to/project"
    }
  ],
  "default": {
    "agent": "omp",
    "project": "default"
  },
  "display": { "mode": "", "footer": true },
  "platforms": [
    {
      "type": "weixin",
      "name": "default",
      "options": {
        "allow_from": "*"
      }
    },
    {
      "type": "wecom",
      "options": {
        "bot_id": "YOUR_BOT_ID",
        "secret": "YOUR_BOT_SECRET",
        "stream": true,
        "allow_from": "*",
        "group_allow_from": "*"
      }
    }
  ]
}
